<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- This repo consumes only public packages. Pin restore to nuget.org so builds are
       reproducible on any machine and Central Package Management has a single, unambiguous
       source (avoids NU1507 dependency-confusion warnings from machine-wide private feeds). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
